PORT=5000
MONGO_URI=<your_mongodb_connection_string>
JWT_SECRET=<generate_with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))">
CLIENT_ORIGIN=http://localhost:5173
# Admin emails are hardcoded in backend/routes/auth.js ADMIN_EMAILS array
# Add or remove emails there to control who gets admin role on registration
